<nav>
    <div class="site-title">
        <a href="/">
            <h1>DevDiaries</h1>
        </a>
        <p>Stories from Creators for Creators</p>
    </div>

    <!-- Hamburger (Visible only on mobile) -->
    <div class="menu-btn" id="menuBtn">
        ☰
    </div>

    <!-- Navigation Links -->
    <ul id="navLinks">
        <li>
            <a href="/blogs" class="<%= activePage === 'blogs' ? 'active-link' : '' %>">
                Blogs
            </a>
        </li>
        <li>
            <a href="/about" class="<%= activePage === 'about' ? 'active-link' : '' %>">
                About
            </a>
        </li>
        <li>
            <a href="/blogs/create" class="<%= activePage === 'create' ? 'active-link' : '' %>">
                New Blog
            </a>
        </li>

        <% if (userId) { %>

            <li>
                <a href="/blogs/dashboard" class="<%= activePage === 'dashboard' ? 'active-link' : '' %>">
                    Dashboard
                </a>
            </li>
            <li class="user-menu">
                <div class="user-dropdown-toggle" id="userDropdown">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Hi, <%= typeof userName !== 'undefined' ? (userName || 'there') : 'there' %></span>
                    <i class="fa-solid fa-chevron-down dropdown-arrow"></i>
                </div>
                <div class="user-dropdown-menu" id="userDropdownMenu">
                    <a href="/analytics"><i class="fa-solid fa-chart-line"></i> Analytics</a>
                    <a href="/blogs/export-report"><i class="fa-solid fa-file-export"></i> Export Learning Report</a>
                    <a href="/blogs/my-posts"><i class="fa-solid fa-file-lines"></i> My Posts</a>
                    <a href="/blogs/my-drafts"><i class="fa-solid fa-pen-to-square"></i> My Drafts</a>
                    <hr>
                    <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                </div>
            </li>
            <% } else { %>
                <li>
                    <a href="/signup" class="nav-cta <%= activePage === 'signup' ? 'active-link' : '' %>">
                        Get Started
                    </a>
                </li>
                <% } %>
    </ul>
</nav>

<script>
    const menuBtn = document.getElementById('menuBtn');
    const navLinks = document.getElementById('navLinks');

    menuBtn.addEventListener('click', () => {
        navLinks.classList.toggle('show');
    });

    // User dropdown functionality
    const userDropdown = document.getElementById('userDropdown');
    const userDropdownMenu = document.getElementById('userDropdownMenu');

    if (userDropdown && userDropdownMenu) {
        userDropdown.addEventListener('click', function (e) {
            e.preventDefault();
            userDropdownMenu.classList.toggle('show');
            this.classList.toggle('active');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function (e) {
            if (!userDropdown.contains(e.target) && !userDropdownMenu.contains(e.target)) {
                userDropdownMenu.classList.remove('show');
                userDropdown.classList.remove('active');
            }
        });
    }
</script>